# EditorConfig – consistent formatting across editors
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go – gofmt enforces tabs (future backend)
[*.go]
indent_style = tab

# Python – 4-space convention (ruff format default)
[*.py]
indent_size = 4

# Makefile – tabs required by make
[Makefile]
indent_style = tab

# Markdown – trailing spaces can be intentional (line breaks)
[*.md]
trim_trailing_whitespace = false
