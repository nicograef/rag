# .env.example — copy to .env and fill in real values. Never commit .env.
#
# Used by: docker-compose.yml, Makefile

# ── Database ──
POSTGRES_USER=rag
POSTGRES_PASSWORD=<your-db-password>
POSTGRES_DB=rag
# Host/port are optional — the load stage defaults to the local Compose stack:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# ── Embedding (embed stage) ──
# Optional performance knobs — the pinned defaults live in src/rag/embed/__init__.py.
# The model tag must match the schema's vector dimension (or run `make reset` after changing it):
# EMBED_MODEL_ID=BAAI/bge-small-en-v1.5
# EMBED_BATCH_SIZE=16

# ── LLM (Ollama) ──
# Host/port are optional — the generate stage defaults to the local Compose stack:
# OLLAMA_HOST=localhost
# OLLAMA_PORT=11434
# Optional generation knobs — the pinned defaults live in src/rag/generate/__init__.py.
# Changing LLM_MODEL_TAG also changes which model `make llm-pull` pulls:
# LLM_MODEL_TAG=granite4:micro
# LLM_NUM_CTX=4096
# LLM_NUM_PREDICT=512
